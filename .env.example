# Required
OPENAI_API_KEY=your-openai-api-key-here

# Optional — set your preferred OpenAI model (e.g. gpt-4o, gpt-4o-mini)
DEFAULT_MODEL=

# Optional — lower values make eval runs more repeatable (default: 0)
DEFAULT_TEMPERATURE=

# Optional — log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=

# Optional — log directory (default: logs/); each run creates logs/agent_YYYYMMDD_HHMMSS.log
LOG_DIR=

# Optional — override per agent
TRANSACTION_SAFETY_MODEL=
TRANSACTION_SAFETY_N_RETRY=
TRANSACTION_SAFETY_TEMPERATURE=
